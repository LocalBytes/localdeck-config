{
  "name": "@localbytes/localdeck-codegen",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "exports": {
    "./virtuals": {
      "types": "./src/virtuals/index.ts",
      "default": "./src/virtuals/index.ts"
    },
    "./esphome-localdeck": {
      "types": "./src/esphome-localdeck.ts",
      "default": "./src/esphome-localdeck.ts"
    },
    "./scripts": {
      "types": "./src/scripts/index.ts",
      "default": "./src/scripts/index.ts"
    }
  },
  "scripts": {
    "make": "pnpm run make:stock && pnpm run make:test",
    "make:stock": "pnpm run make:stock:yaml && esphome compile ./esphome-localdeck.yaml",
    "make:stock:yaml": "tsx ./src/esphome-localdeck-stock.ts > ./esphome-localdeck.yaml",
    "make:stock:run": "pnpm run make:stock:yaml && esphome run ./esphome-localdeck.yaml",
    "make:test": "pnpm run make:test:yaml && esphome compile ./esphome-localdeck-test.yaml",
    "make:test:yaml": "tsx ./src/esphome-localdeck-test.ts > ./esphome-localdeck-test.yaml",
    "make:test:run": "pnpm run make:test:yaml && esphome run ./esphome-localdeck-test.yaml",
    "lint": "tsc --noEmit && eslint src",
    "lint:fix": "tsc --noEmit && eslint src --fix"
  },
  "dependencies": {
    "esphome-config-ts": "github:LocalBytes/esphome-config-ts",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "zod": "^4.4.3",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "tsx": "^4.19.4",
    "typescript-eslint": "^8.59.3"
  }
}
